# Auto-detect text files and normalize line endings to LF in the repo.
* text=auto eol=lf

# C# source and project files — always LF in the repo, checked out
# according to the platform's core.autocrlf setting.
*.cs text diff=csharp
*.csproj text
*.sln text eol=crlf

# Docs
*.md text
*.json text

# Don't touch binaries
*.png binary
*.jpg binary
*.ico binary
*.dat binary
